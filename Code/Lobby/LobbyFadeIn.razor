@using Sandbox
@using Sandbox.UI
@inherits PanelComponent

<root>
    @if (opacity > 0f)
    {
        <div class="fade" style="opacity: @opacity"></div>
    }
</root>

<style>
    .fade {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: #000;
        pointer-events: none;
    }
</style>

@code {
    private const float FadeInDuration = 2f;

    private RealTimeSince enabledFor;
    private float opacity = 1f;

    protected override void OnEnabled()
    {
        base.OnEnabled();
        enabledFor = 0f;
        opacity = 1f;
    }

    protected override void OnUpdate()
    {
        opacity = System.Math.Clamp(1f - ((float)enabledFor / FadeInDuration), 0f, 1f);
    }

    protected override int BuildHash() => System.HashCode.Combine((int)(opacity * 100));
}
