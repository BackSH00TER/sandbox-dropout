@using System.Linq
@using Sandbox;
@using Sandbox.UI;
@inherits PanelComponent

<root>
    @if (!string.IsNullOrEmpty(countdownText))
    {
        <div class="countdown">@countdownText</div>
    }

    @if (isSpectating)
    {
        <div class="spectator">
            <div class="spectator-target">Spectating: @(spectatingName ?? "...")</div>
            <div class="spectator-hints">
                <span class="hint"><kbd>LMB</kbd> Prev</span>
                <span class="hint"><kbd>RMB</kbd> Next</span>
            </div>
        </div>
    }
</root>

<style>
    .countdown {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        display: flex;
        justify-content: center;
        align-items: center;
        font-family: Poppins;
        font-size: 128px;
        font-weight: 900;
        color: white;
        text-shadow: 0px 4px 20px rgba(0, 0, 0, 0.8);
    }

    .spectator {
        position: absolute;
        bottom: 48px;
        left: 0;
        right: 0;
        flex-direction: column;
        align-items: center;
        font-family: Poppins;
        color: white;
        text-shadow: 0px 2px 12px rgba(0, 0, 0, 0.8);
    }

    .spectator-target {
        font-size: 28px;
        font-weight: 700;
        margin-bottom: 8px;
    }

    .spectator-hints {
        flex-direction: row;
        align-items: center;
    }

    .hint {
        font-size: 18px;
        font-weight: 500;
        margin: 0 12px;
        align-items: center;
    }

    .hint kbd {
        background: rgba(0, 0, 0, 0.55);
        border: 1px solid rgba(255, 255, 255, 0.4);
        border-radius: 4px;
        padding: 2px 8px;
        margin-right: 6px;
        font-weight: 700;
    }
</style>

@code {
    [Property] public GameManager GameManager { get; set; }

    private TimeUntil gameStartTimer => GameManager.CountdownTimer;
    private string countdownText;
    private bool isSpectating;
    private string spectatingName;

    protected override void OnUpdate()
    {
        countdownText = gameStartTimer > 0 ? $"Game starts in {(int)gameStartTimer} seconds" : null;

        var localSpectator = Scene.GetAllComponents<Spectator>()
            .FirstOrDefault(s => s.Network.IsOwner);

        isSpectating = localSpectator != null && localSpectator.IsActive;
        spectatingName = isSpectating ? localSpectator.SpectatingName : null;
    }

    protected override int BuildHash() => System.HashCode.Combine(countdownText, isSpectating, spectatingName);
}
