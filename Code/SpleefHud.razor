@using Sandbox.UI;
@inherits PanelComponent

<root>
    @if (!string.IsNullOrEmpty(countdownText))
    {
        <div class="countdown">@countdownText</div>
    }

    @if (isSpectating)
    {
        <div class="spectator">
            <div class="spectator-target">Spectating: @(spectatingName ?? "...")</div>
            <div class="spectator-hints">
                <span class="hint hint-prev">
                    Prev
                    <Image class="glyph" Texture=@Input.GetGlyph("Attack1", InputGlyphSize.Medium, GlyphStyle.Light) />
                </span>
                <span class="hint hint-next">
                    <Image class="glyph" Texture=@Input.GetGlyph("Attack2", InputGlyphSize.Medium, GlyphStyle.Light) /> Next
                </span>
            </div>
        </div>
    }
</root>

@code {
    [Property] public GameManager GameManager { get; set; }

    private TimeUntil gameStartTimer => GameManager.CountdownTimer;
    private string countdownText;
    private bool isSpectating;
    private string spectatingName;

    protected override void OnUpdate()
    {
        countdownText = gameStartTimer > 0 ? $"Game starts in {(int)gameStartTimer} seconds" : null;

        var spectator = SpectatorMode.Current;
        isSpectating = spectator != null && spectator.IsActive;
        spectatingName = isSpectating ? spectator.SpectatingName : null;
    }

    protected override int BuildHash() => System.HashCode.Combine(countdownText, isSpectating, spectatingName,
Input.UsingController);
}
