@using Sandbox;
@using Sandbox.UI;
@inherits PanelComponent

<root>
    @if (!string.IsNullOrEmpty(countdownText))
    {
        <div class="countdown">@countdownText</div>
    }
</root>

<style>
    .countdown {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        display: flex;
        justify-content: center;
        align-items: center;
        font-family: Poppins;
        font-size: 128px;
        font-weight: 900;
        color: white;
        text-shadow: 0px 4px 20px rgba(0, 0, 0, 0.8);
    }
</style>

@code {
    [Property] public GameManager GameManager { get; set; }
    private TimeUntil gameStartTimer => GameManager.CountdownTimer;
    private string countdownText => $"Game starts in {(int)gameStartTimer} seconds";

    protected override void OnUpdate()
    {
        if (gameStartTimer <= 0)
        {
            Enabled = false;
            return;
        }
    }

    protected override int BuildHash() => System.HashCode.Combine(countdownText);
}
